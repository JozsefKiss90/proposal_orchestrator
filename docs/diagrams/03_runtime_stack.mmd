%% ═══════════════════════════════════════════════
%%  RUNTIME EXECUTION STACK & NODE DISPATCH
%% ═══════════════════════════════════════════════

flowchart TB

  %% ══════════════════════════════════════
  %% LEFT SIDE: 3-Layer Call Stack
  %% ══════════════════════════════════════
  subgraph STACK["<b>3-LAYER RUNTIME STACK</b> &nbsp; runner/"]
    direction TB

    subgraph L0["<b>CLI Entry Point</b>"]
      MAIN["<b>__main__.py</b><br/>python -m runner --run-id UUID<br/>--phase N --dry-run --json --verbose"]
    end

    subgraph STEP0["<b>Step 0: Call Slicer</b> (deterministic, pre-DAG)"]
      SLICER["<b>call_slicer.py</b><br/>Extracts target call from grouped WP JSONs<br/>Produces *.slice.json (~5-8KB)<br/>Runs once, before any node dispatch"]
    end

    subgraph L1["<b>Layer 1: DAG Scheduler</b>"]
      direction LR
      SCHED["<b>dag_scheduler.py</b><br/>ManifestGraph<br/>Topological dispatch<br/>RunSummary"]
      GEVAL["<b>gate_evaluator.py</b><br/>Predicate evaluation<br/>deterministic-first"]
      RCTX["<b>run_context.py</b><br/>State persistence"]
      MREAD["<b>manifest_reader.py</b>"]
      GLIB["<b>gate_library.py</b>"]
      GREG["<b>gate_result_registry.py</b><br/>Upstream bootstrap"]
    end

    subgraph L2["<b>Layer 2: Agent Runtime</b>"]
      direction LR
      AGRT["<b>agent_runtime.py</b><br/>Orchestration adapter<br/>Skill sequencing<br/>Failure propagation<br/>can_evaluate_exit_gate"]
      DNORM["<b>dependency_normalizer.py</b><br/>Phase 4 pre-agent<br/>Pure Python"]
      P8P["<b>phase8_canonical_pack.py</b><br/>Reference pack assembly"]
      P8R["<b>phase8_reuse.py</b><br/>Reuse tracking"]
      UPIN["<b>upstream_inputs.py</b><br/>Input resolution"]
    end

    subgraph L3["<b>Layer 3: Skill Runtime</b>"]
      direction LR
      SKRT["<b>skill_runtime.py</b><br/>Prompt assembly<br/>Schema validation<br/>Atomic writes"]
      CLTR["<b>claude_transport.py</b><br/>TAPM: --tools Read,Glob<br/>cli-prompt: stdin pipe"]
      SDISP["<b>semantic_dispatch.py</b><br/>Semantic predicates"]
    end

    subgraph PRED["<b>Predicate Modules</b> &nbsp; runner/predicates/"]
      direction LR
      PF["file"]
      PS["schema"]
      PC["coverage"]
      PSC["scope"]
      PCY["cycle"]
      PT["timeline"]
      PG["gate_pass"]
      PCR["criterion"]
      PP8["phase8"]
      PSR["source_ref"]
    end

    MAIN --> SLICER
    SLICER --> SCHED
    SCHED -->|"dispatches nodes"| AGRT
    SCHED -->|"evaluates gates"| GEVAL
    AGRT -->|"invokes skills"| SKRT
    SKRT -->|"calls Claude"| CLTR
    GEVAL -->|"semantic checks"| SDISP
    SDISP -->|"calls Claude"| CLTR
    GEVAL --- PRED
  end

  %% ══════════════════════════════════════
  %% RIGHT SIDE: Node Dispatch Contract
  %% ══════════════════════════════════════
  subgraph CONTRACT["<b>5-STEP NODE DISPATCH CONTRACT</b>"]
    direction TB

    S1["<b>1. SET RUNNING</b><br/>Persist to RunContext"]
    S2{"<b>2. ENTRY GATE</b><br/>Evaluate"}
    S3["<b>3. EXECUTE BODY</b><br/>run_agent &rarr; run_skill &rarr; Claude"]
    S4{"<b>4. EXIT GATE</b><br/>Evaluate"}
    S5["<b>5. RETURN RESULT</b><br/>NodeExecutionResult"]

    RELEASED["RELEASED"]
    BLOCKED_E["blocked_at_entry"]
    BLOCKED_B["blocked_at_exit<br/><i>origin: agent_body</i>"]
    BLOCKED_G["blocked_at_exit<br/><i>origin: exit_gate</i>"]

    S1 --> S2
    S2 -->|"PASS"| S3
    S2 -->|"FAIL"| BLOCKED_E
    S3 -->|"success +<br/>can_eval = true"| S4
    S3 -->|"failure or<br/>can_eval = false"| BLOCKED_B
    S4 -->|"PASS"| S5
    S4 -->|"FAIL"| BLOCKED_G
    S5 --> RELEASED
  end

  %% ══════════════════════════════════════
  %% BOTTOM: Runtime Models
  %% ══════════════════════════════════════
  subgraph MODELS["<b>RUNTIME CONTRACTS</b> &nbsp; runtime_models.py"]
    direction LR

    SK_RES["<b>SkillResult</b><br/>status, outputs_written<br/>failure_reason<br/>failure_category:<br/>MISSING_INPUT |<br/>MALFORMED_ARTIFACT |<br/>CONSTRAINT_VIOLATION |<br/>INCOMPLETE_OUTPUT |<br/>CONSTITUTIONAL_HALT"]

    AG_RES["<b>AgentResult</b><br/>status<br/>can_evaluate_exit_gate<br/>failure_origin: agent_body<br/>invoked_skills[]"]

    NE_RES["<b>NodeExecutionResult</b><br/>node_id, final_state<br/>failure_origin:<br/>entry_gate | agent_body |<br/>exit_gate | null<br/>exit_gate_evaluated"]

    SK_RES ~~~ AG_RES ~~~ NE_RES
  end

