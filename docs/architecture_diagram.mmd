  %% SECTION 8: NODE DISPATCH CONTRACT
  %% ══════════════════════════════════════════════════════════
  subgraph DISPATCH["<b>5-STEP NODE DISPATCH CONTRACT</b>"]
    direction LR
    step1["<b>1.</b> Set state<br/>to RUNNING"]
    step2["<b>2.</b> Evaluate<br/>ENTRY GATE"]
    step3["<b>3.</b> Execute<br/>NODE BODY<br/>(run_agent)"]
    step4["<b>4.</b> Evaluate<br/>EXIT GATE"]
    step5["<b>5.</b> Return<br/>NodeExecution<br/>Result"]

    step1 --> step2
    step2 -->|"pass"| step3
    step2 -->|"fail"| blocked_entry["blocked_at_entry"]
    step3 -->|"success + can_eval"| step4
    step3 -->|"failure"| blocked_body["blocked_at_exit<br/>(agent_body)"]
    step4 -->|"pass"| step5
    step4 -->|"fail"| blocked_gate["blocked_at_exit<br/>(exit_gate)"]
    step5 --> released["RELEASED"]
  end

