%% ============================================================
%% PROPOSAL ORCHESTRATOR — SYSTEM ARCHITECTURE
%% Horizon Europe DAG-Driven Proposal Generation Engine
%% ============================================================

flowchart TB

  %% ══════════════════════════════════════════════════════════
  %% TITLE BLOCK
  %% ══════════════════════════════════════════════════════════
  title["<b>PROPOSAL ORCHESTRATOR</b><br/><i>Horizon Europe DAG-Driven Proposal Generation Engine</i><br/>───────────────────────────────────────<br/>8 Phases | 13 Nodes | 11 Gates | 102 Predicates<br/>22 Agents | 30 Skills | 3-Layer Runtime Stack"]
  style title fill:#1a0533,stroke:#7c3aed,stroke-width:3px,color:#e0e0ff

  %% ══════════════════════════════════════════════════════════
  %% SECTION 1: RUNTIME EXECUTION STACK
  %% ══════════════════════════════════════════════════════════
  subgraph RUNTIME["<b>RUNTIME EXECUTION STACK</b> &nbsp; runner/"]
    direction TB

    subgraph CLI_LAYER["<b>Layer 0: CLI Entry Point</b>"]
      direction LR
      main["<b>__main__.py</b><br/>CLI argument parsing<br/>--run-id, --phase, --dry-run,<br/>--json, --verbose"]
    end

    subgraph SLICER_LAYER["<b>Step 0: Call Slicer</b> (deterministic pre-processing)"]
      direction LR
      slicer["<b>call_slicer.py</b><br/>Extracts target call entry<br/>from grouped WP JSONs<br/>Produces *.slice.json (~5-8KB)<br/>Runs once per DAG run"]
    end

    subgraph SCHEDULER_LAYER["<b>Layer 1: DAG Scheduler</b>"]
      direction LR
      scheduler["<b>dag_scheduler.py</b><br/>ManifestGraph | RunSummary<br/>Topological dispatch<br/>Stall detection"]
      gate_eval["<b>gate_evaluator.py</b><br/>Predicate evaluation<br/>102 predicates across 11 gates<br/>Deterministic-first, then semantic"]
      run_ctx["<b>run_context.py</b><br/>Per-run state persistence<br/>Node states, failure metadata"]
      manifest["<b>manifest_reader.py</b><br/>Loads manifest.compile.yaml<br/>Resolves node graph"]
      gate_lib["<b>gate_library.py</b><br/>gate_rules_library.yaml<br/>Predicate registry"]
      gate_reg["<b>gate_result_registry.py</b><br/>Bootstrap upstream states<br/>from durable gate results"]
    end

    subgraph AGENT_LAYER["<b>Layer 2: Agent Runtime</b>"]
      direction LR
      agent_rt["<b>agent_runtime.py</b><br/>Orchestration adapter<br/>Sequences skill invocations<br/>Failure propagation<br/>can_evaluate_exit_gate"]
      dep_norm["<b>dependency_normalizer.py</b><br/>Phase 4 deterministic<br/>dependency normalization<br/>(pure Python, pre-agent)"]
      p8_pack["<b>phase8_canonical_pack.py</b><br/>Canonical reference pack<br/>assembly for Phase 8"]
      p8_reuse["<b>phase8_reuse.py</b><br/>Reuse tracking for<br/>Phase 8 drafting nodes"]
      upstream["<b>upstream_inputs.py</b><br/>Resolve declared inputs<br/>from disk per manifest"]
    end

    subgraph SKILL_LAYER["<b>Layer 3: Skill Runtime</b>"]
      direction LR
      skill_rt["<b>skill_runtime.py</b><br/>Claude transport adapter<br/>Prompt assembly | Schema validation<br/>Atomic writes | _validate_skill_output()"]
      transport["<b>claude_transport.py</b><br/>Claude CLI transport layer<br/>TAPM: --tools 'Read,Glob'<br/>cli-prompt: stdin pipe<br/>No API key required"]
      sem_disp["<b>semantic_dispatch.py</b><br/>Semantic predicate dispatch<br/>Constitutional compliance<br/>via Claude invocation"]
    end

    subgraph PREDICATES["<b>Predicate Modules</b> &nbsp; runner/predicates/"]
      direction LR
      pred_file["<b>file_predicates</b><br/>File existence checks"]
      pred_schema["<b>schema_predicates</b><br/>JSON schema conformance"]
      pred_cov["<b>coverage_predicates</b><br/>Cross-artifact coverage"]
      pred_scope["<b>scope_coverage</b><br/>Call scope alignment"]
      pred_cycle["<b>cycle_predicates</b><br/>Dependency acyclicity"]
      pred_time["<b>timeline_predicates</b><br/>Schedule consistency"]
      pred_gate["<b>gate_pass_predicates</b><br/>Upstream gate status"]
      pred_crit["<b>criterion_predicates</b><br/>Phase 8 section checks"]
      pred_p8["<b>phase8_section</b><br/>Section artifact checks"]
      pred_src["<b>source_ref_predicates</b><br/>Source reference validation"]
    end

    subgraph MODELS["<b>Runtime Models</b>"]
      direction LR
      models["<b>runtime_models.py</b><br/>SkillResult | AgentResult<br/>NodeExecutionResult<br/>Failure categories"]
    end

    %% Layer connections
    main --> slicer
    slicer --> scheduler
    scheduler --> gate_eval
    scheduler --> agent_rt
    agent_rt --> skill_rt
    skill_rt --> transport
    gate_eval --> sem_disp
    sem_disp --> transport
  end

