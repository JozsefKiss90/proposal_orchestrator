{
  "schema_id": "orch.phase8.canonical_reference_pack.v1",
  "run_id": "8813ed4e-5c80-4157-a17e-9bed30552962",
  "objectives": [
    {
      "id": "OBJ-1",
      "title": "Neuro-symbolic planning engine for autonomous task decomposition",
      "measurable_target": "Achieve ≥40% improvement in plan success rate over pure LLM-based agent baselines (ReAct, Reflexion) on standardised agent benchmarks (WebArena, SWE-bench, GAIA) for tasks requiring >10 sequential steps.",
      "responsible_partner": "ATU",
      "contributing_partners": [
        "CERIA",
        "BIIS",
        "BAL"
      ]
    },
    {
      "id": "OBJ-2",
      "title": "Unified adaptive memory architecture",
      "measurable_target": "Demonstrate ≥30% improvement in task coherence and factual consistency over context-window-only baselines in interaction sequences exceeding 50 agent steps, measured on MAESTRO's long-horizon evaluation suite.",
      "responsible_partner": "BIIS",
      "contributing_partners": [
        "ATU",
        "BAL"
      ]
    },
    {
      "id": "OBJ-3",
      "title": "Decentralised multi-agent coordination protocols",
      "measurable_target": "Demonstrate effective coordination of ≥5 heterogeneous agents on shared tasks, with ≥25% improvement in joint task completion over independent agent baselines, and formal proof of protocol convergence.",
      "responsible_partner": "CERIA",
      "contributing_partners": [
        "ATU",
        "BIIS"
      ]
    },
    {
      "id": "OBJ-4",
      "title": "Healthcare demonstrator — clinical decision support",
      "measurable_target": "Achieve diagnostic reasoning accuracy within 10% of specialist clinician performance on a benchmark of 500 de-identified clinical cases spanning 5 diagnostic domains, validated by clinical experts at NIHS.",
      "responsible_partner": "NIHS",
      "contributing_partners": [
        "ATU",
        "BIIS",
        "BAL"
      ]
    },
    {
      "id": "OBJ-5",
      "title": "Manufacturing demonstrator — process optimisation",
      "measurable_target": "Demonstrate ≥15% reduction in defect rates and ≥10% reduction in energy consumption compared to baseline operations in a pilot factory environment at ISIA, validated over a 3-month operational period.",
      "responsible_partner": "ISIA",
      "contributing_partners": [
        "ATU",
        "CERIA",
        "BAL"
      ]
    },
    {
      "id": "OBJ-6",
      "title": "Logistics transfer demonstrator — cross-sector generalisation",
      "measurable_target": "Demonstrate ≥20% improvement in disruption recovery time and ≥15% improvement in delivery schedule adherence compared to current planning systems, validated on ELI operational scenarios across 3 supply chain corridors.",
      "responsible_partner": "ELI",
      "contributing_partners": [
        "CERIA",
        "BAL"
      ]
    },
    {
      "id": "OBJ-8",
      "title": "External Tool and API Orchestration Layer",
      "measurable_target": "Typed tool registry supporting ≥30 external tools/APIs across all three demonstrator domains; tool invocation success rate ≥95% with verified output validation; mean recovery time from tool failure ≤5s; full provenance traces for 100% of tool invocations.",
      "responsible_partner": "ATU",
      "contributing_partners": [
        "BIIS",
        "CERIA",
        "BAL"
      ]
    },
    {
      "id": "OBJ-7",
      "title": "Open framework release and ecosystem contribution",
      "measurable_target": "Open-source release with ≥500 GitHub stars within 6 months of release; contributions accepted to AI-on-demand platform; results validated through ≥2 TEFs; technology transfer initiated through ≥3 EDIHs.",
      "responsible_partner": "BAL",
      "contributing_partners": [
        "FIIT",
        "ATU"
      ]
    }
  ],
